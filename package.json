{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "commit": "pnpm dlx czg",
    "commit:validate": "commitlint --edit",
    "commit:frontend": "pnpm --filter web lint && pnpm --filter web check-types",
    "commit:format": "pnpm run format",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.12",
    "typescript": "5.9.2"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    },
    "cz-git": {
      "alias": {
        "wip": "chore: wip"
      },
      "messages": {
        "type": "Selecciona el tipo de cambio:",
        "scope": "Alcance (opcional):",
        "subject": "Descripción corta:",
        "confirmCommit": "Confirmar el commit?"
      },
      "types": [
        {
          "value": "feat",
          "name": "feat: Nueva funcionalidad"
        },
        {
          "value": "fix",
          "name": "fix: Corrección de bug"
        },
        {
          "value": "docs",
          "name": "docs: Documentación"
        },
        {
          "value": "style",
          "name": "style: Formato/estilo"
        },
        {
          "value": "refactor",
          "name": "refactor: Refactor sin cambiar comportamiento"
        },
        {
          "value": "perf",
          "name": "perf: Mejora de rendimiento"
        },
        {
          "value": "test",
          "name": "test: Añadir/ajustar tests"
        },
        {
          "value": "build",
          "name": "build: Cambios de build"
        },
        {
          "value": "ci",
          "name": "ci: Configuración CI"
        },
        {
          "value": "chore",
          "name": "chore: Mantenimiento"
        }
      ],
      "scopes": [
        "web",
        "docs",
        "backend",
        "repo",
        "ui"
      ],
      "useEmoji": false,
      "enableMultipleScopes": false,
      "subjectLimit": 72
    }
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}