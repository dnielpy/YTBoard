[MASTER]
# Add files or directories to the blacklist
ignore=CVS,__pycache__,.venv,venv,.git,node_modules
ignore-paths=alembic/,apps/frontend/

[MESSAGES CONTROL]
# Disable specific checks - focus on errors, unused imports/variables, and code quality
disable=
    too-many-arguments,           # Reduce false positives for common patterns
    too-few-public-methods,       # Allow utility classes
    too-many-instance-attributes, # Pydantic models have many attributes
    missing-module-docstring,     # Optional module docstrings
    duplicate-code,               # Can be overly strict
    line-too-long,                # Handled by formatter (black)
    unused-argument,              # Some functions need unused args
    W0707,                        # Allow missing-from in except clauses

[FORMAT]
max-line-length=120

[DESIGN]
max-attributes=15
max-locals=20

[BASIC]
# These are the check names that will find unused variables/imports
good-names=i,j,k,ex,Run,_

[LOGGING]
logging-format-style=new


