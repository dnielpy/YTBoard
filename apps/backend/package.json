{
  "name": "backend",
  "private": true,
  "scripts": {
    "dev": "./.venv/bin/python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:uv": "uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "docker:up": "docker compose -f docker-compose-dev.yml up",
    "docker:up:d": "docker compose -f docker-compose-dev.yml up -d",
    "docker:down": "docker compose -f docker-compose-dev.yml down"
  }
}