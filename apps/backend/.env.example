# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Application Settings
SECRET_KEY=your-secret-key-here-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
# Example: postgresql+asyncpg://user:password@localhost/ytboard_db
DATABASE_URL=postgresql+asyncpg://user:password@localhost/ytboard_db

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:4000/en/auth/google/callback
